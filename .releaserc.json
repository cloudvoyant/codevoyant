{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {"type": "feat", "section": "Features"},
            {"type": "fix", "section": "Bug Fixes"},
            {"type": "docs", "section": "Documentation"},
            {"type": "refactor", "section": "Code Refactoring"},
            {"type": "perf", "section": "Performance Improvements"},
            {"type": "test", "section": "Tests"},
            {"type": "chore", "hidden": true}
          ]
        },
        "writerOpts": {
          "commitsSort": ["subject", "scope"],
          "commitPartial": "* {{#if scope}}**{{scope}}:** {{/if}}{{subject}}{{#if body}}\n\n{{body}}{{/if}}{{#if footer}}\n\n{{footer}}{{/if}}\n\n"
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "echo ${nextRelease.version} > version.txt && node -e \"const fs=require('fs'); ['dev','em','mem','pm','spec','ux'].forEach(p => { const path = 'plugins/' + p + '/.claude-plugin/plugin.json'; const data = JSON.parse(fs.readFileSync(path)); data.version='${nextRelease.version}'; fs.writeFileSync(path, JSON.stringify(data,null,2)); }); const pkgPath='packages/agent-kit/package.json'; const pkgData=JSON.parse(fs.readFileSync(pkgPath)); pkgData.version='${nextRelease.version}'; fs.writeFileSync(pkgPath, JSON.stringify(pkgData,null,2)+'\\n');\""
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "version.txt", "plugins/dev/.claude-plugin/plugin.json", "plugins/em/.claude-plugin/plugin.json", "plugins/mem/.claude-plugin/plugin.json", "plugins/pm/.claude-plugin/plugin.json", "plugins/spec/.claude-plugin/plugin.json", "plugins/ux/.claude-plugin/plugin.json", "packages/agent-kit/package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "pkgRoot": "packages/agent-kit"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": ["CHANGELOG.md"],
        "addReleases": "bottom"
      }
    ]
  ]
}
